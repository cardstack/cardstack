<ActionCardContainer
  class={{cn "transaction-amount" transaction-amount--data-entered=this.isUnlockingOrUnlocked}}
  @header="Deposit Amount"
  @isComplete={{@isComplete}}
>
  <ActionCardContainer::Section @title="Choose an amount to deposit into the reserve pool">
    <div class="transaction-amount__input-section">
      <Boxel::Field
        class="transaction-amount__field"
        @label="Funding From:"
        @labelClass="transaction-amount__banner-field-label"
      >
        <CardPay::TransactionAmount::BalanceView
        @wallet={{network-display-info "layer1" "fullName"}}
          @tokenSymbol={{this.currentTokenSymbol}}
          @tokenIcon={{this.currentTokenDetails.icon}}
          @address={{this.layer1Network.walletInfo.firstAddress}}
          @balance={{format-token-amount this.currentTokenBalance}}
          @balanceInUsd={{token-to-usd this.tokenSymbolForConversion this.currentTokenBalance}}
          @isComplete={{@isComplete}}
        />
      </Boxel::Field>
      {{#if (or this.isUnlockingOrUnlocked this.isAmountSet)}}
        <Boxel::Field
          class="transaction-amount__field"
          @label={{concat this.amountLabel ":"}}
          data-test-amount-label
        >
          <CardPay::BalanceDisplay
            class="transaction-amount__token"
            @size="large"
            @icon={{this.currentTokenDetails.icon}}
            @balance={{format-token-amount this.amountAsBigNumber}}
            @symbol={{this.currentTokenSymbol}}
            @usdBalance={{token-to-usd this.tokenSymbolForConversion this.amountAsBigNumber}}
            data-test-amount-entered
          />
        </Boxel::Field>
      {{else}}
        <Boxel::Field
          @label={{this.amountLabel}}
          @fieldMode="edit"
          class="transaction-amount__field"
          @labelClass="transaction-amount__input-field-label"
          data-test-amount-label
        >
        <div class="transaction-amount__input-container transaction-amount__input-token-balance">
          {{svg-jar this.currentTokenDetails.icon class="transaction-amount__currency-icon" role="presentation"}}
          <Boxel::Input
            class="transaction-amount__input"
            @id="deposit-amount-input"
            @value={{this.amount}}
            @required={{true}}
            @onInput={{this.onInputAmount}}
            placeholder="0.00"
            autocomplete="off"
            inputmode="decimal"
            data-test-amount-input
          />
          <div class="transaction-amount__currency-text">
            {{this.currentTokenSymbol}}
          </div>
        </div>
        </Boxel::Field>
        <Boxel::Field @label={{concat "Approximate value" (if (eq @flow "withdrawal") "*")}} data-test-approximate-value-label>
          ${{token-to-usd this.tokenSymbolForConversion this.amountAsBigNumber}} USD
        </Boxel::Field>
      {{/if}}
    </div>
    {{#if (eq @flow "withdrawal")}}
      <div class="transaction-amount__footnote" data-test-approximate-value-footnote>
        * The actual value depends on the current exchange rate and is determined at the time of authorization.
      </div>
    {{/if}}
    {{#if this.errorMessage}}
      <div class="transaction-amount__error">
        {{this.errorMessage}} Please try again if you want to continue with this workflow, or contact <a class="transaction-amount__support-link" href="mailto:support@cardstack.com" target="_blank" rel="noopener noreferrer">Cardstack support</a>.
      </div>
    {{/if}}
  </ActionCardContainer::Section>
  {{#if (eq @flow "deposit")}}
    <Boxel::ActionChin @stepNumber={{1}} @state={{this.unlockCtaState}} @disabled={{or @frozen this.unlockCtaDisabled}}>
      <:default as |a|>
        <a.ActionButton data-test-unlock-button {{on "click" this.unlock}}>
          Unlock
        </a.ActionButton>
      </:default>
      <:in-progress as |i|>
        <i.ActionButton data-test-unlock-button>
          Unlocking
        </i.ActionButton>
      </:in-progress>
      <:memorialized as |m|>
        <m.ActionStatusArea data-test-unlock-success-message>
          Unlocked
        </m.ActionStatusArea>
        {{#if this.unlockTxnViewerUrl}}
        <m.InfoArea>
          <Boxel::Button @as="anchor" @size="extra-small" @href={{this.unlockTxnViewerUrl}} target="_blank" rel="noopener">
            View on Etherscan
          </Boxel::Button>
        </m.InfoArea>
        {{/if}}
      </:memorialized>
    </Boxel::ActionChin>
    <Boxel::ActionChin @stepNumber={{2}} @state={{this.depositCtaState}} @disabled={{or @frozen this.depositCtaDisabled}}>
      <:default as |a|>
        <a.ActionButton  {{on "click" this.deposit}} data-test-perform-button>
          Deposit
        </a.ActionButton>
      </:default>
      <:disabled as |d|>
        <d.ActionButton data-test-perform-button>
          Deposit
        </d.ActionButton>
      </:disabled>
      <:in-progress as |i|>
        <i.ActionButton data-test-perform-button>
          Depositing
        </i.ActionButton>
      </:in-progress>
      <:memorialized as |m|>
        <m.ActionStatusArea data-test-success-message>
          Deposited
        </m.ActionStatusArea>
        {{#if this.depositTxnViewerUrl}}
        <m.InfoArea>
          <Boxel::Button @as="anchor" @size="extra-small" @href={{this.depositTxnViewerUrl}} target="_blank" rel="noopener">
            View on Etherscan
          </Boxel::Button>
        </m.InfoArea>
        {{/if}}
      </:memorialized>
    </Boxel::ActionChin>
  {{else}}
    <Boxel::ActionChin
      @state={{this.setAmountCtaState}} @disabled={{this.setAmountCtaDisabled}}
      data-test-transaction-amount
    >
      <:default as |d|>
        <d.ActionButton {{on "click" this.toggleAmountSet}}>
          Set Amount
        </d.ActionButton>
      </:default>
      <:disabled as |d|>
        <d.ActionButton>
          Set Amount
        </d.ActionButton>
      </:disabled>
      <:memorialized as |m|>
        <m.ActionButton {{on "click" this.toggleAmountSet}}>
          Edit
        </m.ActionButton>
      </:memorialized>
    </Boxel::ActionChin>
  {{/if}}
</ActionCardContainer>
